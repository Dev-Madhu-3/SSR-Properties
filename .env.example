# EmailJS Configuration
# Get these values from https://www.emailjs.com/

# Your EmailJS Service ID (e.g., service_xxxxxxxx)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (e.g., template_xxxxxxxx)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Public Key (from Account > API Keys)
VITE_EMAILJS_USER_ID=your_public_key_here

# Note: After setting up EmailJS, rename this file to .env and fill in your actual values
